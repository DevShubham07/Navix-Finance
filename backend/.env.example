# NAVIX backend — local development environment (real AWS dev account).
# Copy to .env for local use. Secrets are NOT stored here: AWS credentials come
# from your AWS profile (~/.aws) via the default credential provider chain, and
# DB credentials come from SSM Parameter Store. Never commit real secrets.

# --- AWS ---
AWS_REGION=ap-south-1
AWS_PROFILE=navix-dev
NAVIX_ENV=dev

# --- S3 (fallbacks; normally provided via SSM /navix/<env>/navix/storage/*) ---
NAVIX_S3_BUCKET=navix-finance-documents-dev
NAVIX_S3_PRESIGN_TTL=900
NAVIX_S3_KMS_KEY_ID=

# --- Database ---
# Preferred: provided via SSM (/navix/dev/spring/datasource/*).
# Env fallback (uncomment to bypass SSM); use sslmode=require for RDS:
# DB_URL=jdbc:postgresql://<RDS_ENDPOINT>:5432/navix?sslmode=require
# DB_USERNAME=navix_app
# DB_PASSWORD=          # do NOT commit a real password

# --- Verification providers (backend-only secrets; not exposed to the frontend) ---
# Signzy is PRIMARY, Digitap is the FALLBACK. This backend/.env is auto-loaded by spring-dotenv,
# so uncommenting the keys below is enough to wire them. Base URLs default to the PREPRODUCTION
# hosts in application.yml — override the *_BASE_URL vars to point at production.
#
# Signzy — raw opaque Authorization token + account unique id (from Signzy support/CSM):
# SIGNZY_TOKEN=                                          # preprod account: penny-drop*/bureau/DigiLocker
# SIGNZY_CLIENT_UNIQUE_ID=info@navixfinance.com          # sent as the x-client-unique-id header
# SIGNZY_BASE_URL=https://api-preproduction.signzy.app   # prod: https://api.signzy.app
# Signzy PRODUCTION account — serves PAN 206AB (unmasked name), reverse-geocode (address), penny-drop:
# SIGNZY_PROD_TOKEN=
# SIGNZY_PROD_BASE_URL=https://api.signzy.app
#
# Digitap — HTTP Basic client_id/secret (differ between preprod and prod):
# DIGITAP_CLIENT_ID=
# DIGITAP_CLIENT_SECRET=
# DIGITAP_SVC_BASE_URL=https://svcdemo.digitap.work      # prod: https://svc.digitap.ai
# DIGITAP_API_BASE_URL=https://apidemo.digitap.work      # prod: https://api.digitap.ai
#
# Provider routing order (default signzy,digitap):
# NAVIX_VERIFICATION_CHAIN=signzy,digitap
