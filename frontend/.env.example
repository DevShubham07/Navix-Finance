# Frontend environment variables. Copy to .env.local for local development.

# Public base URL the browser uses to reach the Next.js BFF (same-origin /api).
# The BFF route handlers then proxy server-side to BACKEND_BASE_URL.
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api

# Server-side base URL used by Next.js (rewrites / server actions) to reach the backend.
BACKEND_BASE_URL=http://localhost:8080

# Secret used to sign/verify the staff session. Set a strong random value.
AUTH_SECRET=

# Demo mode. ON by default (mock data, DemoBar visible). Set to "false" to run
# the UI against the real backend. Keep "true" until the backend is wired.
NEXT_PUBLIC_DEMO_MODE=true

# Google Analytics 4 measurement id (gtag.js). NOT a secret, but env-gated so
# analytics only fires where it's set — leave blank to disable (dev/preview).
# Set this in Vercel prod to switch it on. Mounted site-wide in the root layout.
NEXT_PUBLIC_GA_ID=G-LQWXP9JKMG

# NOTE: Fintrix and DigiLocker client IDs/secrets live ONLY on the backend.
# They must never be exposed to the frontend / browser.
#
# --- For Vercel production ---
# Set BACKEND_BASE_URL to your EC2 backend, e.g. http://<EC2_PUBLIC_IP>:8080
# and NEXT_PUBLIC_API_BASE_URL=/api . See deploy/vercel.env.example.
