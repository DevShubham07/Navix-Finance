# =============================================================================
# NAVIX frontend — environment variables for VERCEL.
# Set these in:  Vercel project > Settings > Environment Variables
# (NOT committed to git — this file is only a reference for what to enter.)
# =============================================================================

# --- Where the browser sends API calls ---------------------------------------
# Same-origin BFF on Vercel. Leave as /api unless you split the API out.
NEXT_PUBLIC_API_BASE_URL=/api

# --- Where the Next.js server (BFF route handlers) reaches the Spring backend --
# This is your EC2 backend's public address. Use HTTPS once you put the backend
# behind a domain + TLS; http://<EC2_PUBLIC_IP>:8080 works for an initial test.
BACKEND_BASE_URL=http://REPLACE_WITH_EC2_PUBLIC_IP:8080

# --- Staff session signing secret --------------------------------------------
# Generate with:  openssl rand -base64 48   (can be the same family as backend AUTH_SECRET)
AUTH_SECRET=REPLACE_WITH_RANDOM_SECRET

# --- Demo mode ----------------------------------------------------------------
# Keep demo mode ON for now so the live site is clickable end-to-end while the
# real backend is still being built. Set to "false" later to switch to real APIs.
NEXT_PUBLIC_DEMO_MODE=true

# --- Google Analytics 4 -------------------------------------------------------
# gtag.js measurement id. Not a secret. Set it here to turn analytics ON in prod;
# omit it in Preview envs if you don't want preview traffic reported.
NEXT_PUBLIC_GA_ID=G-LQWXP9JKMG
