# =============================================================================
# NAVIX backend — PRODUCTION env for the EC2 box.
# Copy this to `backend.env` ON THE EC2 INSTANCE and fill in the real values.
# This file is passed to the container via:  docker run --env-file backend.env ...
#
# DO NOT commit the filled-in backend.env to git. (deploy/*.env is gitignored.)
# =============================================================================

# --- Spring profile -----------------------------------------------------------
# 'prod' keeps the app off application-local.yml. The app starts fine without
# AWS SSM because spring.config.import is marked optional.
NAVIX_ENV=prod

# --- AWS region (for the S3 client) -------------------------------------------
AWS_REGION=ap-south-1

# --- AWS credentials for S3 ---------------------------------------------------
# Preferred (and safest): attach an IAM ROLE to the EC2 instance with S3 access,
# then leave the two lines below COMMENTED OUT — the SDK picks up the role
# automatically (instance metadata). See DEPLOYMENT.md "EC2 IAM role".
#
# Fallback (only if you are NOT using an instance role): paste an access key
# for an IAM user that can read/write the bucket. Less safe — rotate it.
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...

# --- Database (RDS PostgreSQL) ------------------------------------------------
# Paste the RDS endpoint from the Console (RDS > Databases > navix-finance >
# Connectivity & security > Endpoint). Keep ?sslmode=require for TLS.
DB_URL=jdbc:postgresql://REPLACE_WITH_RDS_ENDPOINT:5432/navix?sslmode=require
DB_USERNAME=navix_admin
DB_PASSWORD=REPLACE_WITH_RDS_PASSWORD

# --- S3 bucket for documents --------------------------------------------------
# The exact bucket name you created (must be globally unique).
NAVIX_S3_BUCKET=navix-finance-documents-prod
NAVIX_S3_PRESIGN_TTL=900
# Optional: leave blank to use the bucket's default encryption.
NAVIX_S3_KMS_KEY_ID=

# --- App auth secret ----------------------------------------------------------
# Strong random value. Generate with:  openssl rand -base64 48
AUTH_SECRET=REPLACE_WITH_RANDOM_SECRET

# --- Third-party integrations (backend-only; never exposed to the browser) -----
# Leave blank for now — they are not wired into live flows yet (demo mode on).
FINTRIX_BASE_URL=https://admin.fintrix.tech/__api/api/v1/
FINTRIX_CLIENT_ID=
FINTRIX_CLIENT_SECRET=
DIGILOCKER_BASE_URL=https://admin.fintrix.tech/__api/api/v1/
DIGILOCKER_CLIENT_ID=
DIGILOCKER_CLIENT_SECRET=
